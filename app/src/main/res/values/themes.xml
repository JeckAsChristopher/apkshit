<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme -->
    <style name="Theme.LOCAI" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_surface</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Splash screen — same bg, no action bar -->
    <style name="Theme.LOCAI.Splash" parent="Theme.LOCAI">
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
    </style>

    <!-- Alert Dialog -->
    <style name="Theme.LOCAI.Dialog" parent="Theme.MaterialComponents.DayNight.Dialog.Alert">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSurface">@color/bg_elevated</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="android:textColor">@color/white</item>
        <item name="buttonBarPositiveButtonStyle">@style/Widget.LOCAI.Button.Dialog</item>
        <item name="buttonBarNegativeButtonStyle">@style/Widget.LOCAI.Button.Dialog.Negative</item>
    </style>

    <style name="Widget.LOCAI.Button.Dialog" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
    </style>

    <style name="Widget.LOCAI.Button.Dialog.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

</resources>
