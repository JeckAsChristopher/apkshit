<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#7C6FFF"/>
            <corners android:radius="22dp"/>
            <gradient
                android:startColor="#7C6FFF"
                android:endColor="#5A4FCC"
                android:angle="135"/>
        </shape>
    </item>
    <item android:top="18dp" android:bottom="18dp" android:left="20dp" android:right="20dp">
        <shape android:shape="oval">
            <solid android:color="#DDFFFFFF"/>
        </shape>
    </item>
</layer-list>
