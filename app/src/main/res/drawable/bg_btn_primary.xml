<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#5A4FCC" android:endColor="#4A3FBC" android:angle="135"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#7C6FFF" android:endColor="#5A50DD" android:angle="135"/>
            <corners android:radius="14dp"/>
        </shape>
    </item>
</selector>
