<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Ambient glow (decorative, centered slightly above middle) -->
    <View
        android:id="@+id/glowView"
        android:layout_width="320dp"
        android:layout_height="320dp"
        android:background="@drawable/bg_glow"
        android:layout_centerInParent="true"
        android:layout_marginBottom="60dp"/>

    <!-- Logo + tagline block, centered slightly above middle -->
    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:layout_marginBottom="60dp">

        <View
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/ic_logo_bg"/>

        <TextView
            android:id="@+id/tvLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.20"
            android:text="LOCAI"
            android:textColor="@color/white"
            android:textSize="44sp"/>

        <TextView
            android:id="@+id/tvTagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Fully private · Runs offline"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:letterSpacing="0.08"/>

    </LinearLayout>

    <!-- Bottom status + progress bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="48dp"
        android:paddingBottom="56dp"
        android:layout_alignParentBottom="true">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Checking storage…"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="14dp"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="18dp">

            <View android:id="@+id/dotLeft"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_dot_accent"
                android:alpha="0.2"/>

            <View android:id="@+id/dotCenter"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_dot_accent"
                android:alpha="0.2"/>

            <View android:id="@+id/dotRight"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/bg_dot_accent"
                android:alpha="0.2"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:progressDrawable="@drawable/progress_bar_gradient"
            android:max="100"
            android:progress="0"
            android:visibility="invisible"/>

    </LinearLayout>

</RelativeLayout>
