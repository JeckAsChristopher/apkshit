<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_model_card"
    android:padding="16dp">

    <!-- Selection dot (visible when selected) -->
    <View
        android:id="@+id/selectionDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_selection_dot"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Model name -->
    <TextView
        android:id="@+id/tvModelName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:fontFamily="sans-serif-bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/selectionDot"
        android:layout_marginEnd="8dp"/>

    <!-- Subtitle (quant + context) -->
    <TextView
        android:id="@+id/tvModelSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/tvModelName"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Description -->
    <TextView
        android:id="@+id/tvModelDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_secondary_light"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"
        app:layout_constraintTop_toBottomOf="@id/tvModelSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Badge row -->
    <LinearLayout
        android:id="@+id/badgeRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvModelDescription"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Size badge -->
        <TextView
            android:id="@+id/tvModelSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_size"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="8dp"/>

        <!-- Speed badge -->
        <TextView
            android:id="@+id/tvModelSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_speed"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:layout_marginEnd="8dp"/>

        <!-- Quality stars -->
        <TextView
            android:id="@+id/tvModelQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F4C95D"
            android:textSize="13sp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
