<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_model_card"
    android:padding="16dp">

    <!-- Selection dot — top right -->
    <View
        android:id="@+id/selectionDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/bg_selection_dot"
        android:visibility="invisible"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"/>

    <!-- Model name — top left, stops before selection dot -->
    <TextView
        android:id="@+id/tvModelName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:fontFamily="sans-serif-bold"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_toStartOf="@id/selectionDot"
        android:layout_marginEnd="8dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvModelSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvModelName"
        android:layout_alignParentStart="true"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"/>

    <!-- Description -->
    <TextView
        android:id="@+id/tvModelDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvModelSubtitle"
        android:layout_alignParentStart="true"
        android:layout_marginTop="10dp"
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        android:lineSpacingMultiplier="1.3"/>

    <!-- Badge row -->
    <LinearLayout
        android:id="@+id/badgeRow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/tvModelDescription"
        android:layout_alignParentStart="true"
        android:layout_marginTop="12dp">

        <TextView
            android:id="@+id/tvModelSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_size"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvModelSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_badge_speed"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvModelQuality"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F4C95D"
            android:textSize="13sp"/>

    </LinearLayout>

</RelativeLayout>
