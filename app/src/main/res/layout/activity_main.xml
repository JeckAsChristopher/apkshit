<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Top bar -->
    <RelativeLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/bg_surface">

        <TextView
            android:id="@+id/tvAppName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="20dp"
            android:text="LOCAI"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.15"/>

        <ImageButton
            android:id="@+id/btnClear"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_icon_btn"
            android:src="@drawable/ic_clear"
            android:tint="@color/text_secondary"
            android:contentDescription="Clear memory"/>

        <TextView
            android:id="@+id/tvMemoryBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@id/btnClear"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_badge"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="0 memories"
            android:visibility="invisible"/>

    </RelativeLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Chat area — fills all remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clipToPadding="false"/>

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="How can I help?"
            android:textColor="@color/text_secondary"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- Input row — pinned to bottom -->
    <LinearLayout
        android:id="@+id/inputContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <EditText
            android:id="@+id/etInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="Message LOCAI…"
            android:textColorHint="@color/text_hint"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:maxLines="5"
            android:inputType="textMultiLine|textCapSentences"
            android:imeOptions="actionSend"/>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_send_btn"
            android:src="@drawable/ic_send"
            android:tint="@color/white"
            android:enabled="false"
            android:alpha="0.5"
            android:contentDescription="Send"/>

    </LinearLayout>

</LinearLayout>
